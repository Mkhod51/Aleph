# Keeps indentation, encoding and line endings consistent across editors.
# Values mirror .prettierrc.json so the two never disagree.
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Two trailing spaces are a hard line break in Markdown, so leave them alone.
[*.md]
trim_trailing_whitespace = false
